APP_ENV=local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/rag_db
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.1
# bge-m3 is the default embedding model: genuinely multilingual (100+ languages, including
# Hebrew), 1024-dim. Requires: docker compose exec ollama ollama pull bge-m3
OLLAMA_EMBEDDING_MODEL=bge-m3
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1
EMBEDDING_PROVIDER=ollama
VECTOR_STORE_PROVIDER=qdrant

# EMBEDDING_MODEL overrides OLLAMA_EMBEDDING_MODEL (same LLM_MODEL/OLLAMA_CHAT_MODEL fallback
# pattern) — unset here, so it falls back to OLLAMA_EMBEDDING_MODEL (bge-m3) above. To pin back
# to the legacy English-only nomic-embed-text model instead (NOT recommended for Hebrew content):
#   EMBEDDING_MODEL=nomic-embed-text
#   VECTOR_SIZE=768
#   EMBEDDING_VERSION=v1
# Changing the embedding model/dimension always requires bumping EMBEDDING_VERSION too (below) —
# see "Multilingual embedding model" in ARCHITECTURE.md for why, and how re-index works. Changing
# the embedding model creates a new versioned collection and requires document re-indexing; the
# previous collection's vectors are never deleted automatically.
EMBEDDING_MODEL=
EMBEDDING_VERSION=v2
CHUNKING_VERSION=v1

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
QDRANT_COLLECTION_NAME=documents
# 1024 matches bge-m3's output dimension. Set to 768 if pinning EMBEDDING_MODEL=nomic-embed-text.
VECTOR_SIZE=1024
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=
RAG_ENGINE=custom

# Fallback response language when a question's language can't be determined (e.g. empty,
# punctuation-only, or an exact Hebrew/English word-count tie). Supported: he, en.
DEFAULT_RESPONSE_LANGUAGE=en
PROMPT_CATALOG_VERSION=v2

# Storage abstraction (Phase 2.6/2.7) — selects the FileStorage implementation. 'local' is the
# default so a plain `docker compose up` (without minio) and `make verify` never require MinIO.
FILE_STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=storage/documents

# MinIO settings — only read when FILE_STORAGE_PROVIDER=minio. Values below match
# docker-compose.yml's local-only minio service; never reuse these credentials outside local dev.
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_SECURE=false
MINIO_REGION=
MINIO_PRESIGNED_URL_EXPIRY_SECONDS=3600
MINIO_CREATE_BUCKET_IF_MISSING=true

# Retry/stale-job recovery (Phase 2.8.3). A PROCESSING IngestionJob whose row hasn't been
# touched (updated_at) in this many seconds is treated as an approximate "stale" signal, not
# proof the worker died — see app/services/ingestion_retry_service.py.
INGESTION_STALE_AFTER_SECONDS=900
# Maximum stale PROCESSING jobs recovered per recover_stale_ingestion_jobs() call/script run.
INGESTION_RECOVERY_BATCH_SIZE=50

# Provider HTTP timeouts, in seconds (Phase 2.10) — see docs/deployment/README.md's timeout
# strategy section. Defaults match what was previously hardcoded per provider module.
OLLAMA_EMBEDDING_TIMEOUT_SECONDS=30
OLLAMA_LLM_TIMEOUT_SECONDS=60
OLLAMA_HEALTH_TIMEOUT_SECONDS=5
QDRANT_TIMEOUT_SECONDS=30
MINIO_TIMEOUT_SECONDS=30

# PostgreSQL connection pool (Phase 2.10). Defaults mirror SQLAlchemy's own defaults; tune only
# if you know your deployment's concurrency profile. See docs/deployment/README.md.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# Provider retry policy (Phase 2.10) — bounded exponential backoff with jitter, applied inside
# each provider adapter; only transient failures are retried. See docs/operations/README.md.
PROVIDER_RETRY_MAX_ATTEMPTS=3
PROVIDER_RETRY_BASE_DELAY_SECONDS=0.5
PROVIDER_RETRY_MAX_DELAY_SECONDS=5.0

# CORS (Phase 2.10) — comma-separated list of allowed frontend origins. Empty by default: no
# cross-origin requests are allowed until you name your frontend's origin(s) explicitly. "*" is
# not a supported shorthand — list every origin. Example:
#   CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_ORIGINS=

# Startup dependency validation (Phase 2.10) — off by default so a fresh `docker compose up`
# (before Ollama models are pulled or Alembic migrations run) doesn't block the process from
# starting. Set to true once your deployment is otherwise ready, to fail fast on a bad dependency.
STARTUP_DEPENDENCY_CHECK=false
