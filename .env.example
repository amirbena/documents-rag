APP_ENV=local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/rag_db
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1
EMBEDDING_PROVIDER=ollama
VECTOR_STORE_PROVIDER=qdrant

# EMBEDDING_MODEL overrides OLLAMA_EMBEDDING_MODEL (same LLM_MODEL/OLLAMA_CHAT_MODEL fallback
# pattern) — unset here, so it falls back to OLLAMA_EMBEDDING_MODEL above. For multilingual
# (Hebrew + English) retrieval, pull and switch to a multilingual embedding model instead, e.g.:
#   ollama pull bge-m3
#   EMBEDDING_MODEL=bge-m3
#   VECTOR_SIZE=1024
# Changing the embedding model/dimension always requires bumping EMBEDDING_VERSION too (below) —
# see "Multilingual embedding architecture" in ARCHITECTURE.md for why, and how re-index works.
EMBEDDING_MODEL=
EMBEDDING_VERSION=v1
CHUNKING_VERSION=v1

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
QDRANT_COLLECTION_NAME=documents
VECTOR_SIZE=768
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=
RAG_ENGINE=custom

# Fallback response language when a question's language can't be determined (e.g. empty,
# punctuation-only, or an exact Hebrew/English word-count tie). Supported: he, en.
DEFAULT_RESPONSE_LANGUAGE=en
PROMPT_CATALOG_VERSION=v1
