#!/usr/bin/env bash
# Pre-commit hook: runs `make verify` and blocks the commit if it fails.
#
# Installed via scripts/install-git-hooks.sh (copies this file to .git/hooks/pre-commit).
# Does not auto-fix anything and does not stage/commit any files itself — it only checks.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "Running 'make verify' before commit..."
echo

if make verify; then
    echo
    echo "make verify passed — proceeding with commit."
    exit 0
else
    status=$?
    echo
    echo "make verify failed — commit blocked."
    echo "Fix the reported issue(s) and try committing again."
    echo "To skip this check in an emergency, use: git commit --no-verify"
    exit "$status"
fi
